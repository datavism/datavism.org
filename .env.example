# DATAVISM environment — example values. Copy to `.env` (and `.env.local`) and fill in.
# Only PUBLIC_* vars are exposed to the browser (Astro convention).

# ── Phase 1 · Analytics (live) ────────────────────────────────────────────────
# Cookieless, no PII, no consent banner. Provider-swappable (edit Analytics.astro).
# Umami (default): PUBLIC_UMAMI_SRC = your script URL, PUBLIC_UMAMI_WEBSITE_ID = site id.
# The analytics script only renders in a production build when BOTH are set.
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=

# ── Phase 2 · Identity bridge to data-snack (Firebase, client SDK) ─────────────
# Shared identity lives in the data-snack Firebase project (see docs/INTEGRATION-data-snack.md).
# Copy the web config from data-snack's .env. projectId is `data-snack`.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=data-snack
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# ── Phase 3 · GHOST AI agent (Gemini, server-side only) ────────────────────────
# NOT PUBLIC_ — the key stays server-side in the /api/ghost Vercel function and is
# never shipped to the browser. Gemini 2.5 Flash-Lite (the model family data-snack
# already runs; cheaper than a 70B via NIM for chat).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Rate limit — REQUIRED to run GHOST live (the endpoint fails closed without it, so
# the public AI proxy can never be left uncapped). Protects the Gemini budget with a
# per-IP/minute burst guard + a HARD global daily cap. Free Upstash Redis
# (https://upstash.com): create a Redis DB, copy its REST URL + token here and into
# Vercel prod. Tune the limits in src/lib/ghost/ratelimit.ts (RL_LIMITS).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
