---
// src/components/GhostLogo.astro — the original DATAVISM neon ghost
// (salvaged from legacy-2026 public/brand/svg/, background stripped,
// original path coordinates kept). Subtle eye-blink, reduced-motion gated.
const { size = 72 } = Astro.props
---
<svg
  class="ghost-logo"
  width={size}
  height={size}
  viewBox="-6 -6 144 144"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="DATAVISM ghost logo"
>
  <!-- Magenta shadow (2px offset) -->
  <path
    d="M64,0 a64,64 0 0 1 64,64 v64 c0,0 -16,-12 -32,-12 s-32,12 -32,12 s-16,-12 -32,-12 s-32,12 -32,12 v-64 a64,64 0 0 1 64,-64 z"
    fill="none" stroke="#FF2A6D" stroke-width="12" opacity="0.9" transform="translate(2,2)" />
  <!-- Neon core stroke -->
  <path
    d="M64,0 a64,64 0 0 1 64,64 v64 c0,0 -16,-12 -32,-12 s-32,12 -32,12 s-16,-12 -32,-12 s-32,12 -32,12 v-64 a64,64 0 0 1 64,-64 z"
    fill="none" stroke="#39FF14" stroke-width="10" stroke-linejoin="round" />
  <!-- Eyes -->
  <g class="eyes">
    <circle cx="78" cy="64" r="7" fill="#39FF14" />
    <circle cx="110" cy="64" r="7" fill="#39FF14" />
  </g>
</svg>

<style>
  .ghost-logo .eyes {
    transform-origin: 94px 64px;
    animation: blink 6s infinite;
  }
  @keyframes blink {
    0%, 92%, 100% { transform: scaleY(1); }
    95%, 97% { transform: scaleY(0.08); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ghost-logo .eyes { animation: none; }
  }
</style>
