---
// Marketing footer (3-col): wordmark + ethos line, network links, system meta.
import GhostMark from './GhostMark.astro'
---
<footer class="site-footer">
  <div class="col">
    <div class="brand">
      <GhostMark size={24} />
      <span class="name font-display">DATAVISM</span>
    </div>
    <p class="ethos">See clearer. Build deeper. Resist smarter.</p>
  </div>
  <div class="col">
    <div class="kicker">THE NETWORK</div>
    <div class="dv-nav links">
      <a href="/#network">The Network Map</a>
      <a href="/#lines">The Five Lines</a>
      <a href="/#method">The Method</a>
      <a href="/manifesto">Manifesto</a>
      <a href="/legal">Imprint &amp; privacy</a>
    </div>
  </div>
  <div class="col">
    <div class="kicker">SYSTEM</div>
    <div class="meta">
      <div>version <span class="ink">0.1 · MMXXVI</span></div>
      <div>stations <span class="ink">25</span></div>
      <div>movement <span class="sig">growing</span></div>
      <div>train · build · share · <span class="sig">repeat</span></div>
      <div class="notrack">no tracking on this page. not even ironically.</div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%; padding: 52px 30px 64px;
    display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 40px; align-items: start;
    border-top: 1px solid var(--color-edge);
  }
  .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .name { font-weight: 800; font-size: 17px; letter-spacing: -0.04em; color: var(--color-ink); }
  .ethos { font-size: 19px; line-height: 1.3; color: var(--color-ink-3); max-width: 30ch; margin: 0; font-weight: 500; }
  .kicker { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-4); margin-bottom: 14px; }
  .links { display: grid; gap: 9px; font-family: var(--font-mono); font-size: 12px; }
  .links a { color: var(--color-ink-3); text-decoration: none; width: max-content; }
  .meta { font-family: var(--font-mono); font-size: 11.5px; line-height: 2; color: var(--color-ink-4); }
  .meta .ink { color: var(--color-ink); }
  .meta .sig { color: var(--color-signal); }
  .notrack { margin-top: 10px; color: var(--color-eyebrow); letter-spacing: 0.02em; }
  @media (max-width: 820px) {
    .site-footer { grid-template-columns: 1fr; gap: 28px; padding: 40px 20px 48px; }
  }
</style>
