        ██████████████████        the best way to hide manipulation
      ██████████████████████      is in an algorithm.
     ████████████████████████
    ██████████████████████████    the best way to expose it is to
   ████████████████████████████   ask the right questions.
   ███████████████    ███    ██                            — GHOST
   ███████████████    ███    ██
   ████████████████████████████   ──  next stops on this line  ──
   ████████████████████████████     → /manifesto · why this exists
   █████    ██████████    █████     → the map listens · the ghost sends signals
   ████      ████████      ████     → stationszeichen · 3 cities · Q4 2026
   ███        ██████        ███
   ██          ████          ██   data is infrastructure · awareness is power


-->
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#060608" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="DATAVISM" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <ClientRouter />
  </head>
  <body>
    <div class="topglow" aria-hidden="true"></div>
    <div class="crop crop-tl" aria-hidden="true"></div>
    <div class="crop crop-tr" aria-hidden="true"></div>
    <div class="crop crop-bl" aria-hidden="true"></div>
    <div class="crop crop-br" aria-hidden="true"></div>

    <div class="shell">
      {chrome && <Ticker />}
      {chrome && <SiteHeader active={active} />}
      <main id="top"><slot /></main>
      {footer && <SiteFooter />}
    </div>

    <style>
      .topglow {
        position: fixed; inset: 0; pointer-events: none; z-index: 0;
        background: radial-gradient(58% 40% at 50% 4%, rgba(57, 255, 20, 0.05), transparent 70%);
      }
      .crop { position: fixed; width: 18px; height: 18px; pointer-events: none; z-index: 30; }
      .crop-tl { top: 14px; left: 14px; border-left: 1px solid var(--color-edge-3); border-top: 1px solid var(--color-edge-3); }
      .crop-tr { top: 14px; right: 14px; border-right: 1px solid var(--color-edge-3); border-top: 1px solid var(--color-edge-3); }
      .crop-bl { bottom: 14px; left: 14px; border-left: 1px solid var(--color-edge-3); border-bottom: 1px solid var(--color-edge-3); }
      .crop-br { bottom: 14px; right: 14px; border-right: 1px solid var(--color-edge-3); border-bottom: 1px solid var(--color-edge-3); }
      .shell { position: relative; z-index: 5; min-height: 100vh; display: flex; flex-direction: column; }
      main { flex: 1; }
    </style>

    <script>
      // Drive the data-attribute FX (decode / count-up / glitch). Runs on first
      // load and after every View Transition (astro:page-load fires for both).
      import { initFx } from '../scripts/fx'
      document.addEventListener('astro:page-load', initFx)

      // Quiet console signature — understated, no instructions, no tracking.
      // Runs once (module scripts aren't re-executed across View Transitions).
      console.log(
        '%c DATAVISM %c the data underground',
        'background:#39ff14;color:#07080a;font-weight:700;padding:2px 7px;font-family:ui-monospace,monospace',
        'color:#39ff14;font-family:ui-monospace,monospace',
      )
      console.log(
        '%cdata is infrastructure · awareness is power',
        'color:#8a8f99;font-family:ui-monospace,monospace',
      )
    </script>

    <style is:global>
      /* ② "channel change" — a snappy, slightly glitchy view-transition cut */
      @keyframes fx-vt-out { to { opacity: 0; filter: brightness(2.4) contrast(0.5); } }
      @keyframes fx-vt-in  { from { opacity: 0; filter: brightness(0.25) contrast(3); } }
      ::view-transition-old(root) { animation: fx-vt-out 0.16s steps(2, end) both; }
      ::view-transition-new(root) { animation: fx-vt-in 0.24s steps(3, end) both; }

      /* brief signal-glitch (clip + jitter) for [data-glitch] on first view */
      @keyframes fx-glitch-anim {
        0%   { clip-path: inset(0 0 0 0); transform: none; }
        20%  { clip-path: inset(18% 0 52% 0); transform: translateX(-3px); }
        40%  { clip-path: inset(64% 0 8% 0); transform: translateX(3px); }
        60%  { clip-path: inset(34% 0 38% 0); transform: translateX(-2px); }
        80%  { clip-path: inset(8% 0 70% 0); transform: translateX(2px); }
        100% { clip-path: inset(0 0 0 0); transform: none; }
      }
      .fx-glitch { animation: fx-glitch-anim 0.6s steps(2, end) both; }

      /* ② occasional chromatic-aberration flicker (RGB split) on the wordmark */
      @keyframes fx-aberration {
        0%, 90%, 100% { text-shadow: 0.045em 0.045em 0 #ff2a6d; }
        93% { text-shadow: -0.025em 0 0 #4dd2ff, 0.02em 0 0 #ff2a6d; }
        96% { text-shadow: 0.03em 0 0 #4dd2ff, -0.025em 0 0 #ff2a6d; }
        98% { text-shadow: -0.018em 0 0 #4dd2ff, 0.015em 0 0 #ff2a6d; }
      }
      .fx-aberration { animation: fx-aberration 7s infinite; }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root), ::view-transition-new(root) { animation: none !important; }
        .fx-glitch { animation: none !important; }
        .fx-aberration { animation: none !important; }
      }
    </style>
  </body>
</html>
