---
// src/layouts/Base.astro — global shell for the Evidence Engine site.
// Provides: self-hosted fonts, design tokens, fixed crop-marks + top-glow,
// the utility ticker, the site header (with active nav), and the marketing
// footer. Pages render their own inner max-width inside the full-width slot.
import '../styles/global.css'
// Self-hosted type — no Google Fonts CDN (keeps the no-tracking promise).
import '@fontsource/martian-mono/latin-500.css'
import '@fontsource/martian-mono/latin-600.css'
import '@fontsource/martian-mono/latin-700.css'
import '@fontsource/martian-mono/latin-800.css'
import '@fontsource/spline-sans-mono/latin-400.css'
import '@fontsource/spline-sans-mono/latin-500.css'
import '@fontsource/spline-sans-mono/latin-600.css'
import '@fontsource/spline-sans-mono/latin-700.css'
import '@fontsource/spline-sans-mono/latin-400-italic.css'
import '@fontsource/spline-sans-mono/latin-500-italic.css'

import { ClientRouter } from 'astro:transitions'
import { COPY } from '../lib/copy/en'
import Ticker from '../components/site/Ticker.astro'
import SiteHeader from '../components/site/SiteHeader.astro'
import SiteFooter from '../components/site/SiteFooter.astro'

interface Props {
  title?: string
  description?: string
  image?: string
  active?: 'network' | 'lines' | 'method' | 'manifesto'
  footer?: boolean
  chrome?: boolean // ticker + header; off for focused funnels (onboarding)
}
const {
  title = COPY.meta.title,
  description = COPY.meta.description,
  image = '/og/datavism.png',
  active,
  footer = true,
  chrome = true,
} = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site).href
const ogImage = new URL(image, Astro.site).href
---
<!--


   ██████╗  █████╗ ████████╗ █████╗ ██╗   ██╗██╗███████╗███╗   ███╗
   ██╔══██╗██╔══██╗╚══██╔══╝██╔══██╗██║   ██║██║██╔════╝████╗ ████║
   ██║  ██║███████║   ██║   ███████║██║   ██║██║███████╗██╔████╔██║
   ██║  ██║██╔══██║   ██║   ██╔══██║╚██╗ ██╔╝██║╚════██║██║╚██╔╝██║
   ██████╔╝██║  ██║   ██║   ██║  ██║ ╚████╔╝ ██║███████║██║ ╚═╝ ██║
   ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝  ╚═══╝  ╚═╝╚══════╝╚═╝     ╚═╝
