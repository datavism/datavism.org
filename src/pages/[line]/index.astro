---
// Line overview — line-agnostic. Five station rows + a small (label-less)
// NetworkMap rail. All copy and the accent colour come from the curriculum
// canon (lines.ts). Built only for lines that have at least one open or
// announced station (others stay unbuilt until they launch).
import Base from '../../layouts/Base.astro'
import NetworkMap from '../../components/NetworkMap.svelte'
import { LINES, getLineById } from '../../lib/curriculum/lines'

export async function getStaticPaths() {
  return LINES
    .filter((l) => l.stations.some((s) => s.status === 'open' || s.status === 'announced'))
    .map((l) => ({ params: { line: `line-${l.id}` }, props: { lineId: l.id } }))
}

const { lineId } = Astro.props
const line = getLineById(lineId)
const accent = line.color.hex
const [nameMain, nameSub] = line.name.split(' / ')
const firstOpen = line.stations.find((s) => s.status === 'open')
const others = LINES.filter((l) => l.id !== line.id)
const tagline = (l: (typeof LINES)[number]) => l.mapDescription.replace(/^[A-Z]\s+/, '').replace(/\.$/, '')

const STATUS = { open: 'LIVE NOW', announced: 'ANNOUNCED', locked: 'LOCKED' } as const
const STATUS_COLOR = { open: accent, announced: '#f5b700', locked: '#6b7280' } as const
const rows = line.stations.map((s) => {
  const live = s.status === 'open'
  return {
    ...s,
    href: live ? `/line-${line.id}/${s.slug}` : '#',
    edge: live ? accent : '#20222b',
    codeBg: live ? accent : 'transparent',
    codeFg: live ? '#06120a' : accent,
    titleColor: s.status === 'locked' ? '#a7ada3' : '#f2f1ea',
    statusLabel: STATUS[s.status],
    statusColor: STATUS_COLOR[s.status],
    artifactColor: live ? accent : '#6b7280',
  }
})
---
<Base title={`LINE ${line.code} · ${line.name} — DATAVISM`} description={line.motto} footer={false}>
  <main class="lg" style={`--accent:${accent}`}>
    <!-- HERO -->
    <section class="hero">
      <div class="crumb">NETWORK <span class="sep">/</span> <span class="lname">LINE {line.code}</span></div>
      <div class="id">
        <span class="badge font-display">{line.code}</span>
        <h1 class="font-display title">{nameMain.toUpperCase()}<span class="sep"> / </span>{nameSub?.toUpperCase()}</h1>
      </div>
      <p class="motto">{line.motto}</p>
      {line.intro && <p class="intro">{line.intro}</p>}
      <div class="meta">
        <div><div class="ml">CORE QUESTION</div><div class="ink">{line.coreQuestion}</div></div>
        <div><div class="ml">FINAL ARTIFACT</div><div class="accent">{line.finalArtifact}</div></div>
        <div><div class="ml">STATIONS</div><div class="ink">{line.stations.length} · {firstOpen ? `${firstOpen.code} live now` : 'coming soon'}</div></div>
      </div>
    </section>

    <!-- BODY -->
    <div class="body">
      <div class="main">
        <div class="kicker">// FIVE STOPS</div>
        <div class="rows">
          {rows.map((st) => (
            <a class="row" href={st.href} aria-disabled={st.href === '#' ? 'true' : undefined} style={`border-left:3px solid ${st.edge};`}>
              <span class="rcode" style={`background:${st.codeBg};color:${st.codeFg};border:1px solid ${st.edge};`}>{st.code}</span>
              <span class="rmid">
                <span class="rtitle-row">
                  <span class="font-display rtitle" style={`color:${st.titleColor};`}>{st.title}</span>
                  <span class="rstatus" style={`color:${st.statusColor};border:1px solid ${st.statusColor};`}>{st.statusLabel}</span>
                </span>
                <span class="rrole">{st.role}</span>
              </span>
              <span class="rart"><span class="ral">ARTIFACT</span><span style={`color:${st.artifactColor};`}>{st.artifact}</span></span>
            </a>
          ))}
        </div>
        {firstOpen && (
          <div class="start-wrap">
            <a class="start" href={`/line-${line.id}/${firstOpen.slug}`}>Start the line · {firstOpen.code} →</a>
          </div>
        )}
      </div>

      <!-- RAIL -->
      <aside class="rail">
        <div class="rail-map">
          <div class="rail-kicker">// {line.code} ON THE NETWORK</div>
          <NetworkMap client:visible selected={firstOpen?.id ?? line.stations[0].id} liveLine={line.id} labels={false} accent={accent} />
        </div>
        <div class="rail-why">
          <div class="why-h">WHY THIS LINE</div>
          {line.landingWhy && <p class="why-p">{line.landingWhy}</p>}
          <div class="why-lines">
            {others.map((l) => (
              <div class="why-row"><span class={`cl ${l.id}`}>{l.code}</span> {tagline(l)}</div>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </main>
</Base>

<style>
  .lg { max-width: 1160px; margin: 0 auto; padding: 0 28px; }
  .hero { padding: 40px 0 34px; border-bottom: 1px solid var(--color-edge); }
  .crumb { font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-4); margin-bottom: 24px; }
  .sep { color: var(--color-ink-5); }
  .lname { color: var(--accent); }
  .accent { color: var(--accent); }
  .cl.g { color: var(--color-line-g); } .cl.k { color: var(--color-line-k); } .cl.r { color: var(--color-line-r); } .cl.b { color: var(--color-line-b); } .cl.v { color: var(--color-line-v); }
  .id { display: flex; flex-wrap: wrap; align-items: center; gap: 18px; margin-bottom: 6px; }
  .badge { display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border: 2px solid var(--accent); color: var(--accent); font-weight: 800; font-size: 36px; }
  .title { font-weight: 800; font-size: clamp(34px, 5.5vw, 62px); line-height: 0.96; letter-spacing: -0.04em; margin: 0; }
  .motto { font-size: clamp(17px, 2.2vw, 22px); line-height: 1.35; color: var(--accent); margin: 20px 0 0; }
  .intro { max-width: 62ch; font-size: 15px; line-height: 1.65; color: var(--color-ink-3); margin: 18px 0 0; }
  .meta { display: flex; flex-wrap: wrap; gap: 26px; margin-top: 26px; font-size: 11px; letter-spacing: 0.04em; }
  .ml { color: var(--color-ink-5); margin-bottom: 4px; }
  .ink { color: var(--color-ink); }

  .body { display: grid; grid-template-columns: 1fr 320px; gap: 40px; padding: 36px 0 56px; align-items: start; }
  .main { min-width: 0; }
  .kicker { font-size: 11px; letter-spacing: 0.16em; color: var(--color-ink-4); margin-bottom: 18px; }
  .rows { display: grid; gap: 12px; }
  .row { display: grid; grid-template-columns: auto 1fr auto; gap: 18px; align-items: center; border: 1px solid var(--color-edge); background: var(--color-panel); padding: 18px 20px; text-decoration: none; color: inherit; transition: background .2s ease, border-color .2s ease; }
  .row[aria-disabled='true'] { cursor: default; }
  .row:not([aria-disabled]):hover { background: var(--color-panel-3); }
  .rcode { display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 38px; padding: 0 9px; font-weight: 800; font-size: 17px; }
  .rmid { min-width: 0; }
  .rtitle-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .rtitle { font-weight: 700; font-size: 18px; }
  .rstatus { font-size: 9.5px; letter-spacing: 0.1em; padding: 2px 7px; }
  .rrole { display: block; font-size: 13px; line-height: 1.5; color: var(--color-ink-3); margin-top: 6px; }
  .rart { text-align: right; font-size: 11px; white-space: nowrap; }
  .ral { display: block; color: var(--color-ink-5); margin-bottom: 3px; }
  .start-wrap { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
  .start { display: inline-flex; align-items: center; gap: 10px; font-size: 12.5px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; text-decoration: none; padding: 15px 24px; background: var(--accent); color: #06120a; }

  .rail { position: sticky; top: 20px; display: grid; gap: 16px; }
  .rail-map { border: 1px solid var(--color-edge); background: var(--color-panel-2); padding: 12px; }
  .rail-kicker { font-size: 10px; letter-spacing: 0.14em; color: #46525d; margin-bottom: 6px; padding: 2px 4px; }
  .rail-why { border: 1px solid var(--color-edge); border-top: 3px solid var(--accent); background: var(--color-panel); padding: 18px; }
  .why-h { font-size: 10px; letter-spacing: 0.16em; color: var(--color-ink-4); margin-bottom: 12px; }
  .why-p { font-size: 13px; line-height: 1.6; color: var(--color-ink-3); margin: 0 0 12px; }
  .why-lines { display: grid; gap: 6px; font-size: 12px; line-height: 1.5; color: var(--color-ink-2); }
  .why-row .cl { font-weight: 800; margin-right: 6px; }

  @media (max-width: 940px) {
    .body { grid-template-columns: 1fr; }
    .rail { position: static; }
    .rart { text-align: left; }
  }
</style>
