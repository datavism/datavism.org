---
// /connect — link this DATAVISM session to the shared data-snack identity
// (magic link, no password). The bridge is config-gated (PUBLIC_FIREBASE_*);
// the island handles every state, including "not configured yet".
import Base from '../layouts/Base.astro'
import ConnectFlow from '../components/connect/ConnectFlow.svelte'
---
<Base title="Connect — DATAVISM" description="Link your DATAVISM session to your data-snack identity. One email, no password." footer={false}>
  <main class="cn">
    <section class="hero">
      <div class="crumb">DATAVISM <span class="sep">/</span> <span class="sig">CONNECT</span></div>
      <h1 class="font-display title">CONNECT YOUR IDENTITY</h1>
      <p class="intro">DATAVISM and data-snack share one identity. Connect with the email you already use — no password — and your <strong>codename</strong> carries across both, while your progress saves to your crew record. Until you connect, everything stays local on this device.</p>
      <ConnectFlow client:load />
    </section>
  </main>
</Base>

<style>
  .cn { max-width: 1160px; margin: 0 auto; padding: 0 28px; }
  .hero { padding: 40px 0 56px; }
  .crumb { font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-4); margin-bottom: 22px; }
  .sep { color: var(--color-ink-5); }
  .sig { color: var(--color-signal); }
  .title { font-weight: 800; font-size: clamp(34px, 6vw, 64px); line-height: 0.96; letter-spacing: -0.04em; margin: 0; }
  .intro { max-width: 60ch; font-size: 15px; line-height: 1.65; color: var(--color-ink-3); margin: 18px 0 0; }
  .intro strong { color: var(--color-ink); font-weight: 700; }
</style>
