---
// /ghost — talk to GHOST, the methodological voice of DATAVISM. The chat island
// calls the /api/ghost serverless proxy (Gemini, server-side key); it degrades to
// an "offline" state when the key isn't configured. History is in-memory only.
import Base from '../layouts/Base.astro'
import GhostChat from '../components/ghost/GhostChat.svelte'
---
<Base title="GHOST — DATAVISM" description="Talk to GHOST, the methodological voice of DATAVISM. It helps you turn a vague feeling into a question you can test." footer={false}>
  <main class="gp">
    <section class="hero">
      <div class="crumb">DATAVISM <span class="sep">/</span> <span class="g">GHOST</span></div>
      <h1 class="font-display title">GHOST</h1>
      <p class="intro">The methodological voice of the Evidence Engine. GHOST does not hand you the truth — it helps you ask better, command cleaner and verify harder. Bring a vague suspicion; leave with a question you can test.</p>
      <GhostChat client:load />
    </section>
  </main>
</Base>

<style>
  .gp { max-width: 1160px; margin: 0 auto; padding: 0 28px; }
  .hero { padding: 40px 0 56px; }
  .crumb { font-size: 11px; letter-spacing: 0.14em; color: var(--color-ink-4); margin-bottom: 22px; }
  .sep { color: var(--color-ink-5); }
  .g { color: var(--color-line-g); }
  .title { font-weight: 800; font-size: clamp(40px, 8vw, 92px); line-height: 0.92; letter-spacing: -0.05em; margin: 0; color: var(--color-line-g); }
  .intro { max-width: 60ch; font-size: 15px; line-height: 1.65; color: var(--color-ink-3); margin: 18px 0 0; }
</style>
