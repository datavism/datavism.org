---
// Landing — DATAVISM "Evidence Engine". Recreated from
// docs/design_handoff_datavism/DATAVISM.dc.html. Chrome (ticker/header/footer)
// comes from Base; the Network + Five Lines are one interactive island so a
// click anywhere drives the shared station detail.
import Base from '../layouts/Base.astro'
import NetworkExplorer from '../components/NetworkExplorer.svelte'
import WaitlistForm from '../components/WaitlistForm.svelte'
import { LINES, CURRICULUM_CANON } from '../lib/curriculum/lines'

const oldWay = ['Python', 'SQL', 'Statistics', 'Machine Learning', 'Dashboard']
const progression = CURRICULUM_CANON.progression // Question → … → Intervention
const threeQs = [
  'What hidden system are we looking at?',
  'What method does the rider acquire?',
  'What evidence artifact gets produced?',
]
---
<Base active="network">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-main">
      <div class="eyebrow hero-eyebrow">THE DATA UNDERGROUND</div>
      <h1 class="font-display hero-title">DATAVISM</h1>
      <p class="hero-tag">They track you. <span class="sig">Learn to track back.</span></p>
      <p class="hero-term">&gt; The revolution will be computed.<span class="dv-cursor cur">▋</span></p>
      <p class="hero-sub">You won't learn to code here. You'll learn to <strong>command</strong> — AI, data, and the right questions — and turn what's hidden into public evidence.</p>
      <div class="hero-form">
        <div class="form-eyebrow">// LINE G IS STILL COOKING — GET FIRST ACCESS</div>
        <WaitlistForm client:visible variant="hero" />
        <div class="hero-links">
          <a href="#network">Explore the network →</a>
          <a href="/manifesto">Read the manifesto →</a>
        </div>
      </div>
    </div>

    <aside class="status">
      <div class="status-head"><span>SYSTEM STATUS</span><span class="cooking">◆ STILL COOKING</span></div>
      <div class="status-body">
        <div class="srow"><span class="sk">network</span><span class="cooking">booting</span></div>
        <div class="srow"><span class="sk">lines</span><span class="ink">5 planned</span></div>
        <div class="srow"><span class="sk">stations</span><span class="ink">25</span></div>
        <div class="srow"><span class="sk">first line</span><span class="green">G · THE FOLDER</span></div>
        <div class="srow"><span class="sk">waitlist</span><span class="green">open</span></div>
        <div class="srow srow-top"><span class="sk">you</span><span class="sig">awake <span class="dv-cursor">▋</span></span></div>
      </div>
    </aside>
  </section>

  <!-- NETWORK + FIVE LINES (interactive island) -->
  <NetworkExplorer client:load lines={LINES} accent="#ffd23f" />

  <!-- METHOD -->
  <section id="method" class="method">
    <div class="sec-head">
      <div class="sec-title"><span class="num">03</span><h2 class="font-display h2">The Method</h2></div>
      <span class="kicker-green">// Weapons of Mass Instruction</span>
    </div>
    <div class="method-grid">
      <div>
        <h3 class="font-display method-h3">Story is the interface. Skill is the substance.</h3>
        <div class="method-label">DATAVISM DOES NOT BOARD AT</div>
        <div class="oldway">
          {oldWay.map((w) => <span class="old">{w}</span>)}
        </div>
        <div class="method-label sig-label">IT RUNS</div>
        <div class="progression">
          {progression.map((step, i) => (
            <span class="step-wrap">
              <span class="step">{step}</span>
              {i < progression.length - 1 && <span class="arrow">→</span>}
            </span>
          ))}
        </div>
      </div>
      <div class="three">
        <div class="three-label">EVERY STATION ANSWERS THREE QUESTIONS</div>
        <div class="three-list">
          {threeQs.map((q, i) => (
            <div class="three-row"><span class="three-n">0{i + 1}</span><span class="three-q">{q}</span></div>
          ))}
        </div>
        <div class="datavist">A Datavist: a person who uses data, AI and investigative method to make hidden systems visible.</div>
      </div>
    </div>
  </section>

  <!-- MANIFESTO TEASER -->
  <section id="manifesto-teaser" class="manifesto">
    <div class="manifesto-inner">
      <div class="kicker-yellow">// DATA UNDERGROUND · CLASSIFIED</div>
      <p class="manifesto-line font-display">The data underground exists beneath the noise. <span class="muted">We don't follow the feed.</span> <span class="sig">We build the map.</span></p>
      <div class="manifesto-cells">
        <div class="cell"><div class="cell-h">You are the node.</div><div class="cell-b">No exit without action. The network grows as you move.</div></div>
        <div class="cell"><div class="cell-h">The map is the mission.</div><div class="cell-b">Every truth connects. Every path leads to the Ghost.</div></div>
        <div class="cell"><div class="cell-h">The work is the weapon.</div><div class="cell-b">A Case File is evidence, portfolio and intervention at once.</div></div>
      </div>
      <a class="manifesto-link" href="/manifesto">Read the full manifesto →</a>
    </div>
  </section>

  <!-- WAITLIST BAND -->
  <section id="waitlist" class="band">
    <div class="band-inner">
      <div class="kicker-green band-kicker">// STILL COOKING · NOT LIVE YET</div>
      <h2 class="font-display band-title">Join the underground</h2>
      <p class="band-sub">Line G opens first. Get on the list and you are first through the gate — no spam, just the signal when the doors unlock.</p>
      <div class="band-form"><WaitlistForm client:visible variant="band" /></div>
      <div class="band-foot">no spam · unsubscribe anytime · <span class="ink">datavism.org</span></div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero { max-width: 1560px; margin: 0 auto; padding: 64px 30px 30px; display: grid; grid-template-columns: 1.7fr 1fr; gap: 48px; align-items: end; }
  .hero-eyebrow { font-size: 13px; letter-spacing: 0.34em; color: var(--color-eyebrow); margin-bottom: 26px; }
  .hero-title { font-weight: 800; font-size: clamp(52px, 10.5vw, 156px); line-height: 0.92; letter-spacing: -0.06em; margin: 0; color: var(--color-signal); white-space: nowrap; text-shadow: 0.045em 0.045em 0 var(--color-magenta); }
  .hero-tag { font-size: clamp(16px, 2.1vw, 22px); line-height: 1.4; color: var(--color-ink); margin: 26px 0 12px; }
  .hero-tag .sig { color: var(--color-signal); }
  .hero-term { font-size: clamp(15px, 1.9vw, 20px); line-height: 1.4; color: var(--color-ghost); margin: 0 0 26px; }
  .hero-term .cur { color: var(--color-signal); }
  .hero-sub { max-width: 54ch; font-size: 14px; line-height: 1.65; color: var(--color-ink-3); margin: 0 0 32px; }
  .hero-sub strong { color: var(--color-ink); font-weight: 700; }
  .hero-form { max-width: 540px; }
  .form-eyebrow { font-size: 11px; letter-spacing: 0.16em; color: var(--color-ghost); margin-bottom: 12px; }
  .hero-links { display: flex; flex-wrap: wrap; gap: 18px; margin-top: 18px; font-size: 12px; }
  .hero-links a { color: var(--color-ink-3); text-decoration: none; border-bottom: 1px solid var(--color-edge-3); padding-bottom: 2px; }
  .hero-links a:hover { color: var(--color-signal); }

  .status { border: 1px solid var(--color-edge); background: var(--color-panel); }
  .status-head { display: flex; justify-content: space-between; align-items: center; font-size: 10px; letter-spacing: 0.14em; color: var(--color-ink-4); padding: 11px 16px; border-bottom: 1px solid var(--color-edge); }
  .cooking { color: var(--color-line-k); }
  .status-body { padding: 16px 18px; font-size: 12px; line-height: 2; }
  .srow { display: flex; justify-content: space-between; }
  .srow-top { border-top: 1px solid var(--color-edge); margin-top: 6px; padding-top: 6px; }
  .sk { color: var(--color-ink-4); }
  .ink { color: var(--color-ink); }
  .green { color: var(--color-line-g); }
  .sig { color: var(--color-signal); }

  /* shared section head */
  .sec-head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 12px 16px; margin-bottom: 34px; border-bottom: 1px solid var(--color-edge); padding-bottom: 18px; }
  .sec-title { display: flex; align-items: baseline; gap: 16px; }
  .num { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.16em; color: var(--color-ink-4); }
  .h2 { font-weight: 800; font-size: clamp(26px, 3.4vw, 42px); line-height: 1; letter-spacing: -0.01em; margin: 0; text-transform: uppercase; color: var(--color-ink); }
  .kicker-green { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.16em; color: var(--color-ghost); text-transform: uppercase; white-space: nowrap; }

  /* METHOD */
  .method { max-width: 1560px; margin: 0 auto; padding: 60px 30px; border-top: 1px solid var(--color-edge); }
  .method-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: start; }
  .method-h3 { font-weight: 800; font-size: clamp(28px, 3.6vw, 46px); line-height: 1.04; letter-spacing: -0.01em; margin: 0 0 30px; text-transform: uppercase; color: var(--color-ink); max-width: 16ch; }
  .method-label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em; color: var(--color-ink-5); margin-bottom: 16px; }
  .sig-label { color: var(--color-signal); }
  .oldway { display: flex; flex-wrap: wrap; gap: 9px; align-items: center; margin-bottom: 38px; }
  .old { font-family: var(--font-mono); font-size: 12px; color: var(--color-ink-4); border: 1px dashed var(--color-edge-2); padding: 8px 12px; text-decoration: line-through; }
  .progression { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  .step-wrap { display: inline-flex; align-items: center; gap: 8px; }
  .step { font-family: var(--font-mono); font-size: 13px; color: var(--color-ink); border: 1px solid var(--color-signal); padding: 9px 13px; letter-spacing: 0.03em; }
  .arrow { color: var(--color-signal); font-size: 15px; }
  .three { border: 1px solid var(--color-edge); background: var(--color-panel); padding: 30px; }
  .three-label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em; color: var(--color-ink-5); margin-bottom: 20px; }
  .three-list { display: grid; gap: 18px; }
  .three-row { display: flex; gap: 16px; align-items: baseline; }
  .three-n { font-weight: 900; font-size: 26px; color: var(--color-signal); min-width: 32px; }
  .three-q { font-size: 16px; line-height: 1.45; color: var(--color-ink-2); }
  .datavist { border-top: 1px solid var(--color-edge); margin-top: 24px; padding-top: 18px; font-style: italic; font-weight: 500; font-size: 19px; line-height: 1.3; color: var(--color-ink); }

  /* MANIFESTO TEASER */
  .manifesto { position: relative; padding: 84px 30px; border-top: 1px solid var(--color-edge); background: var(--color-panel); }
  .manifesto-inner { max-width: 1180px; margin: 0 auto; }
  .kicker-yellow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; color: var(--color-signal); margin-bottom: 28px; }
  .manifesto-line { font-weight: 800; font-size: clamp(30px, 5vw, 66px); line-height: 1.0; letter-spacing: -0.015em; text-transform: uppercase; color: var(--color-ink); margin: 0; max-width: 20ch; }
  .manifesto-line .muted { color: var(--color-ink-4); }
  .manifesto-line .sig { color: var(--color-signal); }
  .manifesto-cells { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--color-edge); border: 1px solid var(--color-edge); margin-top: 52px; }
  .cell { background: var(--color-panel); padding: 30px 26px; }
  .cell-h { font-weight: 800; font-size: 26px; line-height: 1.1; text-transform: uppercase; color: var(--color-ink); }
  .cell-b { font-family: var(--font-mono); font-size: 11.5px; color: var(--color-ink-3); margin-top: 16px; line-height: 1.6; }
  .manifesto-link { display: inline-block; margin-top: 36px; font-family: var(--font-mono); font-size: 12.5px; letter-spacing: 0.04em; color: var(--color-signal); text-decoration: none; border-bottom: 1px solid var(--color-edge-3); padding-bottom: 3px; }
  .manifesto-link:hover { border-color: var(--color-signal); }

  /* WAITLIST BAND */
  .band { position: relative; padding: 88px 30px; border-top: 1px solid var(--color-edge); background: var(--color-panel-2); }
  .band-inner { max-width: 760px; margin: 0 auto; text-align: center; }
  .band-kicker { letter-spacing: 0.2em; font-size: 11px; margin-bottom: 22px; }
  .band-title { font-weight: 800; font-size: clamp(30px, 5vw, 58px); line-height: 1.0; letter-spacing: -0.04em; margin: 0; color: var(--color-signal); text-shadow: 0.04em 0.04em 0 var(--color-magenta); }
  .band-sub { font-size: clamp(14px, 1.7vw, 17px); line-height: 1.55; color: var(--color-ink-3); margin: 22px auto 30px; max-width: 52ch; }
  .band-form { max-width: 520px; margin: 0 auto; }
  .band-foot { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em; color: var(--color-ink-4); margin-top: 18px; }
  .band-foot .ink { color: var(--color-ink-3); }

  @media (max-width: 1080px) {
    .hero { grid-template-columns: 1fr; }
    .method-grid { grid-template-columns: 1fr; }
    .manifesto-cells { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Progressive scroll reveals (GSAP, self-hosted via npm). Content is fully
  // visible without JS — we only animate FROM a shifted state, never pre-hide.
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  function run() {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return
    gsap.registerPlugin(ScrollTrigger)
    const ease = 'power3.out'

    gsap.from('.hero-main > *', { y: 36, opacity: 0, duration: 0.75, ease, stagger: 0.09, delay: 0.1 })
    gsap.from('.status', { y: 36, opacity: 0, duration: 0.75, ease, delay: 0.5 })

    const reveal = (sel, vars = {}) =>
      gsap.utils.toArray(sel).forEach((el) =>
        gsap.from(el, { opacity: 0, y: 44, duration: 0.7, ease, scrollTrigger: { trigger: el, start: 'top 86%' }, ...vars }),
      )

    reveal('#network .sec-head')
    reveal('.maprail > *', { y: 54 })
    reveal('#lines .sec-head')
    reveal('.lcard', { y: 48 })
    reveal('.method-grid > *', { y: 46 })
    reveal('.manifesto-line')
    gsap.utils.toArray('.manifesto-cells > .cell').forEach((el, i) =>
      gsap.from(el, { opacity: 0, y: 42, duration: 0.65, ease, delay: i * 0.08, scrollTrigger: { trigger: '.manifesto-cells', start: 'top 85%' } }),
    )
    reveal('.band-inner > *', { y: 36, duration: 0.6 })

    // parallax backdrop word
    gsap.to('.word', { yPercent: -16, ease: 'none', scrollTrigger: { trigger: '#network', start: 'top bottom', end: 'bottom top', scrub: 0.6 } })

    setTimeout(() => ScrollTrigger.refresh(), 500)
  }

  // wait for islands to hydrate so .lcard / .maprail exist
  if (document.readyState === 'complete') requestAnimationFrame(run)
  else window.addEventListener('load', () => requestAnimationFrame(run))
</script>
