---
// /network — a standalone view of the signature network explorer (map + the
// five lines), reusing the same interactive island as the landing section.
import Base from '../layouts/Base.astro'
import NetworkExplorer from '../components/NetworkExplorer.svelte'
import { LINES } from '../lib/curriculum/lines'
---
<Base title="The Map — DATAVISM" description="The octolinear transit map of the Data Underground: five lines, 25 stations, all converging at the Ghost interchange. Every line ends in a public Case File." active="network">
  <NetworkExplorer client:load lines={LINES} accent="#ffd23f" />
</Base>
